# Copy this file to .env and fill in your Supabase project values.
# Find these in your Supabase dashboard: Project Settings -> API.
# The anon key is public by design — data is protected by Row Level Security,
# NOT by keeping this key secret. Never put the service_role key here.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Web Push (notifications). Generate with:  npx web-push generate-vapid-keys
# Only the PUBLIC key goes in the client build (VITE_-prefixed).
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# The following are SERVER-only (set in Vercel, NOT VITE_-prefixed) — used by
# api/notify.js. Do not put the private key in the client.
#   SUPABASE_URL=...            (same as VITE_SUPABASE_URL)
#   SUPABASE_ANON_KEY=...       (same as VITE_SUPABASE_ANON_KEY)
#   VAPID_PUBLIC_KEY=...        (same as VITE_VAPID_PUBLIC_KEY)
#   VAPID_PRIVATE_KEY=...       (secret)
#   VAPID_SUBJECT=you@email.com
